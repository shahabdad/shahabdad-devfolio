# EmailJS configuration for direct inbox form delivery (without backend servers).
# Get your free Service ID, Template ID, and Public Key at https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID_HERE
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID_HERE
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
